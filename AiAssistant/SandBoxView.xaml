<Window x:Class="AiAssistant.SandBoxView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AiAssistant"
        mc:Ignorable="d"
        Title="SandBoxView" Height="450" Width="800" Background="#FF373737">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#FF222222">
            <Label Foreground="White" VerticalAlignment="Center" FontSize="15">
                The AI ​​intends to execute the following command. Do you agree to execute it?
            </Label>
        </Grid>

        <Grid Grid.Row="1">
            <TextBox Name="CommandBox" TextWrapping="Wrap" AcceptsReturn="True" Background="{x:Null}" Foreground="White" BorderThickness="0" BorderBrush="{x:Null}" VerticalScrollBarVisibility="Auto">
            </TextBox>
        </Grid>
        <Grid Grid.Row="2" Background="#FF222222">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 5 0">
                <Border Height="25" CornerRadius="5" Background="#FF883A0A" Margin="5 0 0 0" Cursor="Hand" PreviewMouseDown="Deny">
                    <Label HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Padding="20 0 20 0">
                        Deny
                    </Label>
                </Border>
                <Border Height="25" CornerRadius="5" Background="#FF0782C7" Margin="10 0 0 0" Cursor="Hand" Padding="10 0 10 0" PreviewMouseDown="Allow">
                    <Label HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White">
                        Allow
                    </Label>
                </Border>
            </StackPanel>
        </Grid>
       
       
    </Grid>
</Window>
