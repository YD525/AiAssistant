<Window x:Class="AiAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AiAssistant"
        mc:Ignorable="d"
        Title="AiAssistant" Height="750" Width="800" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid Background="#FF383737">
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="5 0 5 0" Grid.Row="1">
            <Border CornerRadius="9" Background="#FF525252" Cursor="Hand" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="10 0 10 0">
                    <Ellipse Width="5" Height="5" Fill="Black">
                    </Ellipse>
                    <Label Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                        CMDUnit
                    </Label>
                </StackPanel>
            </Border>

            <Border CornerRadius="9" Background="#FF525252" Cursor="Hand" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="10 0 10 0">
                    <Ellipse Width="5" Height="5" Fill="Black">
                    </Ellipse>
                    <Label Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                        CSharpCodeUnit
                    </Label>
                </StackPanel>
            </Border>

            <Border CornerRadius="9" Background="#FF525252" Cursor="Hand" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="10 0 10 0">
                    <Ellipse Width="5" Height="5" Fill="Black">
                    </Ellipse>
                    <Label Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                        IOUnit
                    </Label>
                </StackPanel>
            </Border>

            <Border CornerRadius="9" Background="#FF525252" Cursor="Hand" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="10 0 10 0">
                    <Ellipse Width="5" Height="5" Fill="Black">
                    </Ellipse>
                    <Label Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                        MouseUnit
                    </Label>
                </StackPanel>
            </Border>

            <Border CornerRadius="9" Background="#FF525252" Cursor="Hand" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="10 0 10 0">
                    <Ellipse Width="5" Height="5" Fill="Black">
                    </Ellipse>
                    <Label Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                        RequestUnit
                    </Label>
                </StackPanel>
            </Border>

            <Border CornerRadius="9" Background="#FF525252" Cursor="Hand" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="10 0 10 0">
                    <Ellipse Width="5" Height="5" Fill="Black">
                    </Ellipse>
                    <Label Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
                        WinApiUnit
                    </Label>
                </StackPanel>
            </Border>

            <Border Height="25" CornerRadius="5" Background="#FF0782C7"  VerticalAlignment="Center" Margin="5 0 0 0" Cursor="Hand">

                <Label HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White">
                    AI Config
                </Label>

            </Border>

        </StackPanel>


        <Grid Grid.Row="2">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Foreground="White" FontSize="30">
                    Tell me what you need me to do?
                </Label>

                <Border CornerRadius="9" Background="#FF525252" Height="100" Margin="0 10 0 0">
                    <TextBox Margin="5" FontSize="17" VerticalScrollBarVisibility="Auto" Foreground="White" CaretBrush="White" TextWrapping="Wrap" AcceptsReturn="True" Name="InputBox" Background="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}">
                    </TextBox>
                </Border>

                <CheckBox Name="CSandbox" Foreground="White" Margin="0 5 0 5" IsChecked="True" Click="CSandbox_Click">
                    Enable Sandbox
                </CheckBox>

                <Border Height="25" CornerRadius="5" Background="#FF0782C7" Margin="0 10 0 0" Cursor="Hand" PreviewMouseDown="CallAI">
                    <Label HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White">
                        Execute
                    </Label>
                </Border>

                <TextBox IsReadOnly="True" Name="Log" Height="100" Margin="0 5 0 0" VerticalScrollBarVisibility="Auto" Foreground="White" CaretBrush="White" Background="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}">
                </TextBox>
            </StackPanel>
           
        </Grid>


    </Grid>
</Window>
