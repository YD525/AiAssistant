<Window x:Class="AiAssistant.AIConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AiAssistant"
        mc:Ignorable="d"
        Title="AIConfig" Height="350" Width="500">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ChatGpt
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ApiKey
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center">
                    </TextBox>

                    <Label Margin="5 0 0 0">
                        Model
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center">
                        gpt-4.1-nano
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        Gemini
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ApiKey
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center">
                    </TextBox>

                    <Label Margin="5 0 0 0">
                        Model
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center">
                        gemini-2.5-flash
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        LMStudio
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        Port
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center">
                        1234
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>
        </StackPanel>
       
        
        
    </Grid>
</Window>
