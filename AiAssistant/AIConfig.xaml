<Window x:Class="AiAssistant.AIConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AiAssistant"
        mc:Ignorable="d"
        Title="AIConfig" Height="350" Width="500" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ChatGpt
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ApiKey
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="ChatGptKey" TextChanged="ChatGptKey_TextChanged">
                    </TextBox>

                    <Label Margin="5 0 0 0">
                        Model
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="ChatGptModel" TextChanged="ChatGptModel_TextChanged">
                        gpt-4.1-nano
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center" Name="ChatGptCheck" Click="ChatGptCheck_Click">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        Gemini
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ApiKey
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="GeminiKey" TextChanged="GeminiKey_TextChanged">
                    </TextBox>

                    <Label Margin="5 0 0 0">
                        Model
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="GeminiModel" TextChanged="GeminiModel_TextChanged">
                        gemini-2.5-flash
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center" Name="GeminiCheck" Click="GeminiCheck_Click">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        Claude
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        ApiKey
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="ClaudeKey" TextChanged="ClaudeKey_TextChanged">
                    </TextBox>

                    <Label Margin="5 0 0 0">
                        Model
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="ClaudeModel" TextChanged="ClaudeModel_TextChanged">
                        claude-sonnet-4-5-20250929
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center" Name="ClaudeCheck" Click="ClaudeCheck_Click">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Label>
                        LMStudio
                    </Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label>
                        Port
                    </Label>
                    <TextBox Width="150" VerticalContentAlignment="Center" Name="LMPort" TextChanged="LMPort_TextChanged">
                        1234
                    </TextBox>

                    <CheckBox Margin="5 0 0 0" VerticalAlignment="Center" Name="LMStudioCheck" Click="LMStudioCheck_Click">
                        Enable
                    </CheckBox>
                </StackPanel>
            </StackPanel>
        </StackPanel>
       
        
        
    </Grid>
</Window>
